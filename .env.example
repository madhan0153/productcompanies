# Supabase (region: ap-south-1)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Server-only admin allowlist. Comma-separated; trim-safe and case-insensitive in code.
# Leave unset to fail closed: no one can access /admin.
ADMIN_EMAILS=founder@example.com,security-admin@example.com

# Never create NEXT_PUBLIC_* copies of service-role keys, cron secrets, API keys,
# webhook secrets, or admin allowlists. NEXT_PUBLIC_* is shipped to browsers.

# ─────────────────────────────────────────────────────────────────────────
#                              LLM API keys
# ─────────────────────────────────────────────────────────────────────────
# Provider URLs, model cascades, and capabilities are hardcoded in
# packages/shared/src/llm/providers-preset.ts. You only configure API keys
# here. Every key var accepts comma-separated values for rotation:
#   GROQ_API_KEY=gsk_one,gsk_two,gsk_three
#
# Routing order on Gemini exhaustion: Groq → Cerebras → SambaNova → NVIDIA
#   → Mistral → Fireworks → DeepInfra → Together → OpenRouter
#   → Cloudflare → GitHub Models → HuggingFace → Cohere
#   → (embeddings-only) Voyage → Jina
#   → (self-hosted) FreeLLMAPI
#
# Set as many or as few as you want. The router only activates presets whose
# env keys are present. Skip any provider you don't want in your chain.

# ── Google Gemini (primary; multimodal PDF support) ───────────────────────
# Free tier: https://aistudio.google.com/apikey  (create multiple in
# different Google accounts — quotas are per project per model).
GEMINI_API_KEY=<key1>,<key2>,<key3>

# ── Fast LPU/wafer-scale providers (free, no card) ────────────────────────

# Groq — fastest free LLM (~300 tok/s); Llama 3.3 70B + Mixtral + Gemma2.
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=<gsk_...>

# Cerebras — even faster than Groq for Llama models; free dev tier.
# Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=<csk-...>

# SambaNova — free tier, Llama-3.x family up to 405B.
# Sign up: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=<...>

# ── Cloud GPU providers with free starter credits ─────────────────────────

# NVIDIA NIM — 1,000 free credits on signup, OpenAI-compatible.
# Sign up: https://build.nvidia.com  →  Get API Key
NVIDIA_API_KEY=<nvapi-...>

# Mistral AI — free dev tier on La Plateforme, includes embeddings.
# Sign up: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=<...>

# Fireworks AI — $5 starter credit, OpenAI-compatible.
# Sign up: https://fireworks.ai → Account → API Keys
FIREWORKS_API_KEY=<...>

# DeepInfra — $5 starter credit, broad model selection + embeddings.
# Sign up: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=<...>

# Together AI — monthly free credits, also offers embeddings.
# Sign up: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=<...>

# ── Aggregators ───────────────────────────────────────────────────────────

# OpenRouter — broad model catalog; `:free` suffix routes to free pool.
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=<sk-or-v1-...>

# Cloudflare Workers AI — 10k Neurons/day free. Needs BOTH the API token
# AND your Cloudflare account ID (account ID is part of the URL).
# Sign up: https://dash.cloudflare.com → AI → Workers AI → Manage API Tokens
# Account ID: dash → right sidebar of any Workers AI page.
# CLOUDFLARE_API_KEY=<...>
# CLOUDFLARE_ACCOUNT_ID=<32-hex-string>

# GitHub Models — free for GitHub users, rate-limited per token per day.
# Sign up: https://github.com/settings/personal-access-tokens/new
# Use a fine-grained PAT with the `models:read` scope.
GITHUB_MODELS_API_KEY=<github_pat_...>

# Hugging Face Inference Router — free credits monthly, OpenAI-compatible.
# Sign up: https://huggingface.co/settings/tokens (use a "read" or "fine-grained" token)
HF_API_KEY=<hf_...>

# Cohere — free trial tier (slow but unlimited duration), OpenAI compat.
# Sign up: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=<...>

# ── Dedicated embedding providers (text routing skips these) ──────────────

# Voyage AI — 200M tokens free for the first 6 months, then 1M/month.
# Sign up: https://www.voyageai.com  →  Dashboard  →  API Keys
VOYAGE_API_KEY=<pa-...>

# Jina AI — 1M tokens/month free, no card required.
# Sign up: https://jina.ai  →  API  →  New API Key
JINA_API_KEY=<jina_...>

# ── Self-hosted fallback ──────────────────────────────────────────────────
# Run your own FreeLLMAPI / litellm / vllm proxy and point us at it.
# FREELLMAPI_BASE_URL=http://your-proxy.internal/v1
# FREELLMAPI_API_KEY=<proxy-key>

# ── Optional LLM controls ─────────────────────────────────────────────────
# Deterministic fallbacks keep crawler/matching online when EVERY provider
# is exhausted. Recommended: leave on.
LLM_ENABLE_DETERMINISTIC_FALLBACKS=true

# Emergency kill switch. Set to true to disable the entire OpenAI-compatible
# provider chain regardless of which keys are set. Gemini still runs.
# LLM_FORCE_BLOCK_FREE_PROVIDERS=false

# ── Resend ───────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-resend-key>
RESEND_FROM_EMAIL=ProdMatch.ai <noreply@yourdomain.com>

# Dodo Payments (primary India launch gateway)
# Create products in Dodo Dashboard, then paste their product IDs here.
DODO_PAYMENTS_API_KEY=<dodo_api_key>
DODO_PAYMENTS_WEBHOOK_KEY=<dodo_webhook_secret>
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Optional override. Defaults to test/live Dodo API base URL by environment.
# DODO_PAYMENTS_BASE_URL=https://test.dodopayments.com
DODO_PRODUCT_PRO_MONTHLY_ID=<prod_pro_monthly>
DODO_PRODUCT_PRO_YEARLY_ID=<prod_pro_yearly>
DODO_PRODUCT_CAREER_SPRINT_MONTHLY_ID=<prod_career_sprint_monthly>
DODO_PRODUCT_CAREER_SPRINT_YEARLY_ID=<prod_career_sprint_yearly>
DODO_PRODUCT_TAILOR_CREDITS_50_ID=<prod_tailor_credits_50>

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app

# Optional public analytics tag. Public by design; do not put secret analytics
# API keys in NEXT_PUBLIC_* variables.
# NEXT_PUBLIC_CLARITY_ID=<public-clarity-project-id>

# DPDP policy version — increment when privacy policy text changes
DPDP_POLICY_VERSION=1

# Random secret for Vercel Cron auth + unsubscribe link HMAC signing
# Generate with: openssl rand -hex 32
CRON_SECRET=<run: openssl rand -hex 32>

# ── Admin ─────────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that can access /admin/* pages
# AND act as superusers (full Career Sprint entitlements, no paywalls).
# REQUIRED for admin access. If unset, /admin/* returns 404 for everyone
# and no override is applied (regular billing behavior).
# Email comparison is case-insensitive and trimmed.
# Example: ADMIN_EMAILS=you@company.com,co-admin@company.com
ADMIN_EMAILS=<your-admin-email@example.com>

# Optional IndexNow ownership key. Generate a random 32+ char token and add the
# same value to Vercel/GitHub Actions when enabling /api/cron/indexnow.
INDEXNOW_KEY=<random-indexnow-key>

# Optional server-side crawler drift alerts. Keep this server-only; webhooks are secrets.
# CRAWL_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# E2E tests only (never set in production)
E2E_TEST_EMAIL=e2e-test@yourdomain.com
