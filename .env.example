# Supabase (region: ap-south-1)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Google Gemini (free tier — https://aistudio.google.com/apikey)
# Comma-separate multiple keys for round-robin rotation when rate limits are hit
GEMINI_API_KEY=<key1>,<key2>,<key3>

# Optional LLM provider chain after Gemini is exhausted.
# OpenAI-compatible providers are tried in the order below. Keep raw keys in env only.
# FreeLLMAPI-style proxy example:
# LLM_PROVIDER_CHAIN=gemini,freellmapi
# FREE_LLM_API_BASE_URL=http://localhost:8000/v1
# FREE_LLM_API_KEYS=<proxy-key-1>,<proxy-key-2>
# FREE_LLM_API_MODEL=<openai-compatible-free-text-model>
# FREE_LLM_API_EMBEDDING_MODEL=<optional-openai-compatible-embedding-model>
#
# Privacy gates. Leave both false until provider retention/DPDP terms are reviewed.
# Public JD parsing and job embeddings may use external providers by default.
LLM_ALLOW_FREE_PROVIDER_DERIVED_RESUME=false
LLM_ALLOW_FREE_PROVIDER_RESUME_PII=false
LLM_ENABLE_DETERMINISTIC_FALLBACKS=true

# Resend (https://resend.com)
RESEND_API_KEY=re_<your-resend-key>
RESEND_FROM_EMAIL=ProdMatch.ai <noreply@yourdomain.com>

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app

# DPDP policy version — increment when privacy policy text changes
DPDP_POLICY_VERSION=1

# Random secret for Vercel Cron auth + unsubscribe link HMAC signing
# Generate with: openssl rand -hex 32
CRON_SECRET=<run: openssl rand -hex 32>

# E2E tests only (never set in production)
E2E_TEST_EMAIL=e2e-test@yourdomain.com
