# Supabase (region: ap-south-1)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── LLM API keys ──────────────────────────────────────────────────────────
#
# Provider URLs, model cascades, and capabilities are all hardcoded in
# packages/shared/src/llm/providers-preset.ts. You only configure API keys
# here. Each provider you give a key to is automatically added to the
# fallback chain (in the order declared in providers-preset.ts).
#
# When Gemini's daily quota is hit, the router rolls through:
#   Gemini  →  Groq  →  OpenRouter  →  Cerebras  →  Together  →  FreeLLMAPI
#
# Within each provider it cascades models AND keys, so 10 keys × 4 models
# = 40 chances per provider before moving on.

# Google Gemini (primary; multimodal PDF support)
# Free tier: https://aistudio.google.com/apikey  (create multiple in
# different Google accounts — quotas are per-project).
GEMINI_API_KEY=<key1>,<key2>,<key3>

# Groq (fastest free LLM; Llama 3.3 70B et al.)
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=<gsk_...>

# OpenRouter (broad model selection; :free suffix models)
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=<sk-or-v1-...>

# Cerebras (very fast Llama-3 inference)
# Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=<csk-...>

# Together AI (monthly free credits; also offers embeddings)
# Sign up: https://api.together.xyz
TOGETHER_API_KEY=<...>

# FreeLLMAPI self-hosted proxy. Set the URL too if hosted off-localhost.
# FREELLMAPI_API_KEY=<...>
# FREELLMAPI_BASE_URL=http://your-proxy.internal/v1

# ── Optional LLM controls ────────────────────────────────────────────────
#
# Deterministic fallbacks keep crawler/matching online when EVERY LLM provider
# is exhausted. Falls back to hash vectors for embeddings and rule-based
# summaries for explanations. Recommended: leave on.
LLM_ENABLE_DETERMINISTIC_FALLBACKS=true

# Emergency kill switch. Set to true to disable the entire OpenAI-compatible
# provider chain regardless of which keys are set. Gemini still runs.
# LLM_FORCE_BLOCK_FREE_PROVIDERS=false

# ── Resend ───────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-resend-key>
RESEND_FROM_EMAIL=ProdMatch.ai <noreply@yourdomain.com>

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app

# DPDP policy version — increment when privacy policy text changes
DPDP_POLICY_VERSION=1

# Random secret for Vercel Cron auth + unsubscribe link HMAC signing
# Generate with: openssl rand -hex 32
CRON_SECRET=<run: openssl rand -hex 32>

# E2E tests only (never set in production)
E2E_TEST_EMAIL=e2e-test@yourdomain.com
